root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx}]
charset = utf-8
indent_style = space
indent_size = 2

[*.json]
charset = utf-8
indent_style = space
indent_size = 2

[*.css]
charset = utf-8
indent_style = space
indent_size = 2

[*.md]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{sh,py}]
charset = utf-8
end_of_line = lf

[{Makefile,*.mk}]
indent_style = tab
