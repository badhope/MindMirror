.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #8b5cf6, #a855f7);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(139, 92, 246, 0.3);
}

.logo {
  width: 100rpx;
  height: 100rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  min-width: 180rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.section {
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  display: block;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  transition: all 0.2s;
}

.feature-card:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

.feature-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-icon-text {
  font-size: 40rpx;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.feature-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-left: 16rpx;
}

.hot-scroll {
  white-space: nowrap;
  width: 100%;
}

.hot-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-right: 20rpx;
  min-width: 200rpx;
  vertical-align: top;
}

.hot-card:active {
  background: rgba(255, 255, 255, 0.1);
}

.hot-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.hot-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.hot-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  margin-top: 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
  line-height: 1.6;
}
