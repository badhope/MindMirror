.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(180deg, #16213e 0%, #1a1a2e 100%);
}

.header {
  text-align: center;
  padding: 60rpx 0;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  line-height: 160rpx;
  font-size: 80rpx;
  margin: 0 auto 30rpx;
  background: rgba(233, 69, 96, 0.1);
  border-radius: 50%;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #e94560;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #8a8a8a;
}

.stats {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
  margin-bottom: 40rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #8a8a8a;
}

.features {
  padding: 40rpx 0;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.feature-text {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #8a8a8a;
}

.actions {
  padding-top: 40rpx;
}

.primary-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #e94560 0%, #c73e54 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(233, 69, 96, 0.3);
}

.primary-btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.6s ease-out forwards;
}

.slide-up {
  animation: slideUp 0.5s ease-out forwards;
}

.pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(233, 69, 96, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 0 20rpx rgba(233, 69, 96, 0);
  }
}