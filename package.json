{
  "name": "human-os-reborn",
  "version": "2.3.0",
  "description": "HumanOS - Professional Frontend Framework Showcase Platform | 专业前端框架展示平台",
  "author": {
    "name": "HumanOS Team",
    "email": "contact@humanos.dev",
    "url": "https://github.com/badhope"
  },
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "private": false,
  "homepage": "https://aiskill.qzz.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/badhope/HumanOS.git"
  },
  "bugs": {
    "url": "https://github.com/badhope/HumanOS/issues"
  },
  "keywords": [
    "frontend-framework",
    "react-showcase",
    "typescript",
    "vite",
    "tailwindcss",
    "modern-web",
    "ui-components",
    "design-system",
    "enterprise-platform",
    "react",
    "framer-motion",
    "three.js",
    "web-app",
    "progressive-web-app",
    "open-source",
    "professional-platform",
    "frontend-architecture",
    "react-ecosystem",
    "现代前端",
    "企业级应用",
    "框架展示"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "clean": "rm -rf dist node_modules/.vite",
    "prepare": "husky install || true",
    "init": "node scripts/init.js",
    "template:graduation": "node scripts/init.js --type=graduation",
    "template:enterprise": "node scripts/init.js --type=enterprise",
    "template:personal": "node scripts/init.js --type=personal",
    "create:assessment": "node scripts/create-assessment.js",
    "docs:serve": "npx serve docs",
    "analyze": "npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.15.11",
    "@use-gesture/react": "^10.3.0",
    "canvas-confetti": "^1.9.2",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.5",
    "gsap": "^3.12.3",
    "lenis": "^1.0.42",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "tailwind-merge": "^2.1.0",
    "three": "^0.158.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/three": "^0.158.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
