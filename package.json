{
  "name": "mindmirror",
  "version": "1.1.0",
  "private": false,
  "description": "MindMirror is an open-source, self-hostable, privacy-first psychological assessment platform: Big Five personality (60), PSS-10 stress, GAD-7 anxiety, SSRS social support (43), MBI-GS burnout (40), SWLS life satisfaction (40), CD-RISC-10 resilience (40), mood tracking and mental training programs.",
  "description_zh": "MindMirror 是一个开源、可自托管、隐私优先的心理测评平台：大五人格 (60 题)、PSS-10 压力、GAD-7 焦虑、SSRS 社会支持 (43 题)、MBI-GS 职业倦怠 (40 题)、SWLS 生活满意度 (40 题)、CD-RISC-10 心理韧性 (40 题)、心情追踪与心理训练。",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/postbuild.mjs",
    "build:pages": "tsc -b && vite build --base=/MindMirror/ && node scripts/postbuild.mjs",
    "deploy:pages": "npm run build:pages && touch dist/.nojekyll && npx gh-pages -d dist -b gh-pages -m 'deploy: GitHub Pages build'",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"*.{json,md,yml,yaml}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/MindMirror.git"
  },
  "keywords": [
    "psychology",
    "personality-assessment",
    "big-five",
    "ocean",
    "neo-pi-r",
    "ipip",
    "mental-health",
    "self-discovery",
    "self-hosted",
    "privacy",
    "stress-test",
    "pss-10",
    "anxiety-assessment",
    "gad-7",
    "social-support",
    "ssrs",
    "burnout",
    "mbi-gs",
    "maslach",
    "life-satisfaction",
    "swls",
    "diener",
    "resilience",
    "cd-risc",
    "connor-davidson",
    "mood-tracker",
    "mental-training",
    "cbt",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "framer-motion",
    "fastapi",
    "postgresql",
    "docker",
    "pwa",
    "open-source"
  ],
  "author": {
    "name": "badhope",
    "url": "https://github.com/badhope"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/badhope/MindMirror/issues"
  },
  "homepage": "https://badhope.github.io/MindMirror/",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/badhope"
    }
  ],
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.19.19",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.0.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
