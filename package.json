{
  "name": "jingxin",
  "version": "0.1.0",
  "private": true,
  "description": "Jingxin (镜心) is a static, privacy-first tool that maps your answers across a 12-dimensional trait space to a historical figure — literary masters of China first, then more. All math runs in the browser; nothing is sent to a server.",
  "description_zh": "镜心 —— 一面问己之镜。以十二维特征空间将汝之答映射至千古人物，先就东方文人墨客，再及其余。纯前端、纯本地、无后端、无账号。",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base=/MindMirror/",
    "deploy:pages": "npm run build:pages && touch dist/.nojekyll && npx gh-pages -d dist -b gh-pages -m 'deploy: GitHub Pages build'",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/golden.spec.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"*.{json,md,yml,yaml}\"",
    "gen:portraits": "node scripts/gen-portraits.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/MindMirror.git"
  },
  "keywords": [
    "jingxin",
    "镜心",
    "trait-space",
    "personality",
    "historical-figures",
    "literati",
    "东方文人",
    "matching",
    "static-site",
    "github-pages",
    "privacy",
    "localstorage",
    "react",
    "typescript",
    "vite",
    "tailwindcss"
  ],
  "author": {
    "name": "badhope",
    "url": "https://github.com/badhope"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "noncommercial": true,
  "bugs": {
    "url": "https://github.com/badhope/MindMirror/issues"
  },
  "homepage": "https://badhope.github.io/MindMirror/",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/badhope"
    }
  ],
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  }
}
