# MindMirror Backend Configuration
# Copy this file to .env before running the backend.

# --- Database ---
# In Docker Compose, host is the service name `postgres`.
# For local dev (no Docker), point this at your local Postgres or use sqlite:///./mental_health.db
DATABASE_URL=postgresql://mental_user:mental_password@postgres:5432/mental_health_db

# --- Security ---
# IMPORTANT: change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-in-production-please-use-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS ---
# Comma-separated list of allowed origins, or * for any (development only).
CORS_ORIGIN=*
